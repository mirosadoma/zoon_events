{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint . --max-warnings=0",
        "openapi:lint": "redocly lint specs/001-project-foundation/contracts/openapi.yaml",
        "openapi:phase1": "redocly lint specs/002-registration-ticketing-credentials/contracts/openapi.yaml",
        "openapi:phase2": "redocly lint specs/003-wallet-passes-scanning/contracts/openapi.yaml",
        "openapi:phase3": "redocly lint specs/004-kiosk-badge-printing-manual-desk/contracts/openapi.yaml",
        "openapi:phase4": "redocly lint specs/005-acs-access-control/contracts/openapi.yaml",
        "openapi:phase5": "redocly lint specs/007-identity-verification/contracts/openapi.yaml",
        "openapi:phase6": "redocly lint specs/009-venue-marketplace/contracts/openapi.yaml",
        "openapi:sync": "php scripts/sync-openapi.php --check",
        "test": "vitest run",
        "test:browser": "vitest run resources/js/__tests__/*-browser.test.tsx",
        "test:phase6": "vitest run resources/js/pages/tenant/marketplace resources/js/pages/tenant/venues resources/js/pages/platform/marketplace",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@inertiajs/react": "^3.6.0",
        "axios": "^1.11.0",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "html5-qrcode": "^2.3.8",
        "leaflet": "^1.9.4",
        "lucide-react": "^1.23.0",
        "qrcode.react": "^4.2.0",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "react-i18next": "^17.0.8",
        "react-leaflet": "^5.0.0",
        "tailwind-merge": "^3.3.1"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.10.2",
        "@eslint/js": "^9.31.0",
        "@redocly/cli": "^2.36.0",
        "@tailwindcss/vite": "^4.0.0",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.2",
        "@types/leaflet": "^1.9.21",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.0.0",
        "autoprefixer": "^10.4.21",
        "axe-core": "^4.10.3",
        "concurrently": "^9.0.1",
        "eslint": "^9.31.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^16.3.0",
        "jsdom": "^26.1.0",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.5.6",
        "shadcn": "^4.12.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.9.2",
        "typescript-eslint": "^8.37.0",
        "vite": "^7.0.7",
        "vitest": "^3.2.4"
    }
}
