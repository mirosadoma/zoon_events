APP_NAME=Zonetec
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zonetec
DB_USERNAME=root
DB_PASSWORD=

DB_TESTING_HOST=127.0.0.1
DB_TESTING_PORT=3306
DB_TESTING_DATABASE=zonetec_testing
DB_TESTING_USERNAME=zonetec_testing
DB_TESTING_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=zonetec

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="foundation@example.test"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

ZONETEC_NAME=Zonetec
ZONETEC_DEPLOYMENT_MODE=saas
TENANCY_HEADER=X-Tenant-ID
TENANCY_REQUIRED=true
TENANCY_PRIVATE_STORAGE_ROOT=tenants

AUDIT_DRIVER=database
AUDIT_HMAC_ALGORITHM=hmac-sha256-v1
AUDIT_CURRENT_KEY_ID=key-1
AUDIT_KEY_RING={"key-1":"xL2UxeUPxDwh7folzkm/GuVxB9K8KTC+YSrSGuiX8C4="}
AUDIT_EXPORT_EXPIRY_MINUTES=60
AUDIT_RETENTION_DAYS=365

FEATURE_FLAGS_DEFAULT_STATUS=draft

OBSERVABILITY_LOG_CHANNEL=stack
OBSERVABILITY_METRICS_DRIVER=null
OBSERVABILITY_TRACING_DRIVER=null
OBSERVABILITY_ERROR_TRACKING_DRIVER=null

INTEGRATIONS_DEFAULT_ADAPTER=fake
INTEGRATIONS_ALLOW_NETWORK=false
